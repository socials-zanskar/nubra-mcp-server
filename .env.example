# Copy this file to .env locally. Do not commit your real phone number, MPIN, or session files.
PHONE=
# Optional SDK-compatible alias. If omitted, the MCP will mirror PHONE into PHONE_NO automatically.
PHONE_NO=
MPIN=
NUBRA_ENV=UAT
NUBRA_DEFAULT_EXCHANGE=NSE
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
MCP_PATH=/mcp
AUTH_STATE_FILE=auth_state.json
